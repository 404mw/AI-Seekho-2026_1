# Supabase Project Configurations (Get these from Supabase dashboard -> Settings -> API)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# API Base URL (Point to your local development backend or GCP Cloud Run URL)
# - For local development: http://localhost:8000/api/v1 (use machine IP e.g. http://192.168.x.x:8000/api/v1 if testing on physical mobile device)
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
